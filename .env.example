# Application
APP_NAME=nalssi
LOG_LEVEL=INFO
DEBUG=false

# Database
# SQLite (default for local development):
DATABASE_URL=sqlite:///./nalssi.db
# PostgreSQL (used by docker-compose):
# DATABASE_URL=postgresql://nalssi:nalssi@localhost:5432/nalssi

# Security
SECRET_KEY=your-secret-key-here-change-in-production
API_KEY_ENCRYPTION_KEY=your-encryption-key-change-in-production

# Weather APIs
NOAA_API_BASE_URL=https://api.weather.gov
OPEN_METEO_API_BASE_URL=https://api.open-meteo.com/v1
WEATHERAPI_API_KEY=

# Collection
DEFAULT_COLLECTION_INTERVAL=300   # seconds (5 minutes) - current weather + alerts
FORECAST_COLLECTION_INTERVAL=3600  # seconds (1 hour) - forecasts
MAX_CONCURRENT_COLLECTIONS=5

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# InfluxDB (optional)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=
INFLUXDB_BUCKET=weather

# Server
API_HOST=0.0.0.0
API_PORT=8000
